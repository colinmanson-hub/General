{
  "name": "spirograph-studio",
  "version": "1.0.0",
  "description": "Spirograph Studio — animated geometric designs",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "dist": "electron-builder"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js", "**/tests/**/*.test.cjs"]
  },
  "build": {
    "appId": "com.spirograph.studio",
    "productName": "Spirograph Studio",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "index.html",
      "styles.css",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  }
}
