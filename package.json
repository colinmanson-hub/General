{
  "name": "spirograph-studio",
  "version": "1.0.0",
  "description": "Spirograph Studio — animated geometric designs with audio visualization",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.spirograph.studio",
    "productName": "Spirograph Studio",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  }
}
